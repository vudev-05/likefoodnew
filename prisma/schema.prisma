/// Chiến dịch flash sale theo thời gian
model flashsalecampaign {
  id        Int                @id @default(autoincrement()) @map("ma_chien_dich")
  name      String             @map("ten_chien_dich")
  startAt   DateTime           @map("ngay_bat_dau")
  endAt     DateTime           @map("ngay_ket_thuc")
  isActive  Boolean            @default(true) @map("dang_hoat_dong")
  createdAt DateTime           @default(now()) @map("ngay_tao")
  updatedAt DateTime           @updatedAt @map("ngay_cap_nhat")
  products  flashsaleproduct[]

  @@index([startAt, endAt])
  @@index([isActive])
  @@map("chien_dich_flash_sale")
}

/// Sản phẩm tham gia flash sale
model flashsaleproduct {
  id             Int               @id @default(autoincrement()) @map("ma_san_pham_flash_sale")
  campaignId     Int               @map("ma_chien_dich")
  productId      Int               @map("ma_san_pham")
  flashSalePrice Float             @map("gia_khuyen_mai")
  stockLimit     Int?              @map("gioi_han_so_luong")
  soldCount      Int               @default(0) @map("so_luong_da_ban")
  createdAt      DateTime          @default(now()) @map("ngay_tao")
  updatedAt      DateTime          @updatedAt @map("ngay_cap_nhat")
