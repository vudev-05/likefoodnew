/// Bài viết / Tin tức blog
model post {
  id          Int         @id @default(autoincrement()) @map("ma_bai_viet")
  title       String      @map("tieu_de")
  titleEn     String?     @map("tieu_de_en")
  slug        String      @unique @map("duong_dan_tinh")
  summary     String?     @db.Text @map("tom_tat")
  summaryEn   String?     @db.Text @map("tom_tat_en")
  content     String      @db.LongText @map("noi_dung")
  contentEn   String?     @db.LongText @map("noi_dung_en")
  image       String?     @map("anh_dai_dien")
  authorName  String?     @default("LIKEFOOD") @map("ten_tac_gia")
  category    String?     @default("Tin tức") @map("danh_muc")
  categoryEn  String?     @default("News") @map("danh_muc_en")
  isPublished Boolean     @default(true) @map("da_xuat_ban")
  publishedAt DateTime    @default(now()) @map("ngay_xuat_ban")
  createdAt   DateTime    @default(now()) @map("ngay_tao")
  updatedAt   DateTime    @updatedAt @map("ngay_cap_nhat")
  images      postimage[]

  @@index([isPublished])
  @@index([publishedAt])
  @@map("bai_viet")
}

/// Ảnh trong bài viết
model postimage {
  id        Int      @id @default(autoincrement()) @map("ma_anh")
  postId    Int      @map("ma_bai_viet")
  imageUrl  String   @map("duong_dan_anh")
  altText   String?  @map("van_ban_thay_the")
  order     Int      @default(0) @map("thu_tu_hien_thi")
  createdAt DateTime @default(now()) @map("ngay_tao")
  post      post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("anh_bai_viet")
}

/// Tin nhắn liên hệ từ khách hàng
model contactmessage {
  id        Int      @id @default(autoincrement()) @map("ma_lien_he")
  name      String   @map("ho_ten")
  email     String   @map("thu_dien_tu")
  phone     String?  @map("so_dien_thoai")
  subject   String   @map("tieu_de")
  message   String   @db.Text @map("noi_dung")
  status    String   @default("PENDING") @map("trang_thai")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @default(now()) @updatedAt @map("ngay_cap_nhat")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("tin_nhan_lien_he")
}

/// Cài đặt hệ thống dạng key-value
model systemsetting {
  id        Int      @id @default(autoincrement()) @map("ma_cai_dat")
  key       String   @unique @map("khoa")
  value     String   @db.Text @map("gia_tri")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @default(now()) @updatedAt @map("ngay_cap_nhat")

  @@index([key])
  @@map("cai_dat_he_thong")
}

/// Danh sách yêu thích của người dùng
model wishlist {
  id        Int      @id @default(autoincrement()) @map("ma_yeu_thich")
  userId    Int      @map("ma_nguoi_dung")
  productId Int      @map("ma_san_pham")
  createdAt DateTime @default(now()) @map("ngay_tao")
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("danh_sach_yeu_thich")
}

/// Đăng ký nhận bản tin email
model newslettersubscriber {
  id           Int      @id @default(autoincrement()) @map("ma_dang_ky")
  email        String   @unique @map("thu_dien_tu")
  subscribedAt DateTime @default(now()) @map("ngay_dang_ky")

  @@index([subscribedAt])
  @@map("dang_ky_nhan_ban_tin")
}

