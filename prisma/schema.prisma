  createdAt  DateTime @default(now()) @map("ngay_tao")

  @@index([createdAt])
  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
