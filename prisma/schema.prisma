  error            String?  @map("loi_phat_sinh") @db.Text
  userId           Int?     @map("ma_nguoi_dung")
  sessionId        String?  @map("ma_phien_lam_viec") @db.VarChar(100)
  createdAt        DateTime @default(now()) @map("ngay_tao")

  @@index([task])
  @@index([createdAt])
  @@index([userId])
  @@map("nhat_ky_su_dung_ai")
}

/// Sự kiện hành vi người dùng (click, xem, tìm kiếm…)
model BehaviorEvent {
