/// Lịch sử giao dịch điểm tích lũy
model pointtransaction {
  id          Int      @id @default(autoincrement()) @map("ma_giao_dich_diem")
  userId      Int      @map("ma_nguoi_dung")
  amount      Int      @map("so_diem")
  type        String   @map("loai_giao_dich")
  description String?  @map("mo_ta")
  orderId     Int?     @map("ma_don_hang")
  createdAt   DateTime @default(now()) @map("ngay_tao")
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("giao_dich_diem_thuong")
}

// ============================================================
// CHAT TRỰC TIẾP (HỖ TRỢ KHÁCH HÀNG)
// ============================================================

/// Phiên chat hỗ trợ khách hàng
model livechat {
  id        Int               @id @default(autoincrement()) @map("ma_phien_chat")
  userId    Int               @map("ma_nguoi_dung")
  adminId   Int?              @map("ma_quan_tri_vien")
  status    String            @default("OPEN") @db.VarChar(20) @map("trang_thai")
  subject   String?           @map("chu_de")
  createdAt DateTime          @default(now()) @map("ngay_tao")
  updatedAt DateTime          @updatedAt @map("ngay_cap_nhat")
  closedAt  DateTime?         @map("ngay_dong")
  admin     user?             @relation("adminLiveChats", fields: [adminId], references: [id])
  user      user              @relation("userLiveChats", fields: [userId], references: [id], onDelete: Cascade)
  messages  livechatmessage[]

  @@index([userId])
  @@index([adminId])
  @@index([status])
  @@index([createdAt])
  @@map("phien_chat_truc_tiep")
}

/// Tin nhắn trong phiên chat hỗ trợ
model livechatmessage {
  id         Int      @id @default(autoincrement()) @map("ma_tin_nhan")
  chatId     Int      @map("ma_phien_chat")
  senderType String   @db.VarChar(10) @map("loai_nguoi_gui")
  senderId   Int?     @map("ma_nguoi_gui")
  content    String   @db.Text @map("noi_dung")
  isRead     Boolean  @default(false) @map("da_doc")
  createdAt  DateTime @default(now()) @map("ngay_tao")
  chat       livechat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
  @@index([isRead])
  @@map("tin_nhan_chat")
}

