  @@index([milestoneId])
  @@index([status])
  @@index([couponId])
  @@map("phan_thuong_moc_gioi_thieu")
}

/// Yêu cầu rút tiền hoa hồng về tài khoản ngân hàng
model referralcashout {
  id              Int       @id @default(autoincrement()) @map("ma_yeu_cau_rut_tien")
  userId          Int       @map("ma_nguoi_dung")
  amount          Decimal   @map("so_tien") @db.Decimal(12, 2)
  method          String    @map("phuong_thuc") @db.VarChar(20)
  destinationData String?   @map("thong_tin_nhan_tien") @db.Text
  status          String    @default("PENDING") @map("trang_thai") @db.VarChar(12)
  adminNote       String?   @map("ghi_chu_admin") @db.Text
  processedBy     Int?      @map("ma_nguoi_xu_ly")
  processedAt     DateTime? @map("ngay_xu_ly")
  createdAt       DateTime  @default(now()) @map("ngay_tao")
  updatedAt       DateTime  @updatedAt @map("ngay_cap_nhat")
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("yeu_cau_rut_tien_gioi_thieu")
}

/// Nhật ký kiểm toán hệ thống giới thiệu (audit log)
model referralauditlog {
  id           Int      @id @default(autoincrement()) @map("ma_nhat_ky")
  actorUserId  Int?     @map("ma_nguoi_thuc_hien")
  targetUserId Int?     @map("ma_nguoi_bi_tac_dong")
  action       String   @map("hanh_dong") @db.VarChar(50)
  entityType   String?  @map("loai_thuc_the") @db.VarChar(30)
  entityId     Int?     @map("ma_thuc_the")
  beforeData   String?  @map("du_lieu_truoc") @db.LongText
  afterData    String?  @map("du_lieu_sau") @db.LongText
  metadata     String?  @map("thong_tin_bo_sung") @db.Text
  createdAt    DateTime @default(now()) @map("ngay_tao")
  target       user?    @relation("AuditTarget", fields: [targetUserId], references: [id])
  actor        user?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("nhat_ky_he_thong_gioi_thieu")
}

/// Tín hiệu gian lận trong quan hệ giới thiệu
model referralfraudsignal {
  id         Int              @id @default(autoincrement()) @map("ma_tin_hieu")
  relationId Int              @map("ma_quan_he")
  signalType String           @map("loai_tin_hieu") @db.VarChar(30)
  severity   String           @default("MEDIUM") @map("muc_do_nghiem_trong") @db.VarChar(10)
  score      Int              @default(10) @map("diem_gian_lan")
  details    String?          @map("chi_tiet") @db.Text
  createdAt  DateTime         @default(now()) @map("ngay_tao")
  relation   referralrelation @relation(fields: [relationId], references: [id], onDelete: Cascade)

  @@index([relationId])
  @@index([signalType])
  @@index([severity])
  @@index([createdAt])
  @@map("tin_hieu_gian_lan_gioi_thieu")
}

/// Giao dịch ví hoa hồng giới thiệu
model referralwallettx {
  id           Int      @id @default(autoincrement()) @map("ma_giao_dich")
  userId       Int      @map("ma_nguoi_dung")
  type         String   @map("loai_giao_dich") @db.VarChar(20)
  sourceType   String?  @map("loai_nguon_giao_dich") @db.VarChar(20)
  sourceId     Int?     @map("ma_nguon_giao_dich")
  direction    String   @map("chieu_giao_dich") @db.VarChar(6)
  amount       Decimal  @map("so_tien") @db.Decimal(12, 2)
  balanceAfter Decimal  @map("so_du_sau_giao_dich") @db.Decimal(12, 2)
  status       String   @default("COMPLETED") @map("trang_thai") @db.VarChar(12)
  description  String?  @map("mo_ta") @db.Text
  createdAt    DateTime @default(now()) @map("ngay_tao")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([direction])
  @@index([createdAt])
  @@map("giao_dich_vi_gioi_thieu")
}

/// Cấu hình các section hiển thị trên trang chủ
model homepageSection {
  id          Int       @id @default(autoincrement()) @map("ma_section")
  key         String    @unique @map("khoa_section") @db.VarChar(100)
  title       String?   @map("tieu_de") @db.VarChar(255)
  subtitle    String?   @map("phu_de") @db.VarChar(500)
  description String?   @map("mo_ta") @db.Text
  config      String?   @map("cau_hinh") @db.LongText
  type        String    @default("grid") @map("loai_section") @db.VarChar(50)
  isActive    Boolean   @default(true) @map("kich_hoat")
  position    Int       @default(0) @map("vi_tri")
  limit       Int       @default(10) @map("gioi_han_hien_thi")
  startAt     DateTime? @map("thoi_gian_bat_dau")
  endAt       DateTime? @map("thoi_gian_ket_thuc")
  createdAt   DateTime  @default(now()) @map("ngay_tao")
  updatedAt   DateTime  @default(now()) @updatedAt @map("ngay_cap_nhat")

  @@index([isActive])
  @@index([position])
  @@map("khung_trang_chu")
}
