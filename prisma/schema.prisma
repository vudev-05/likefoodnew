generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Tài khoản người dùng (khách hàng và admin)
model user {
  id                           Int                       @id @default(autoincrement()) @map("ma_nguoi_dung")
  email                        String                    @unique @map("thu_dien_tu")
  password                     String?                   @map("mat_khau")
  name                         String?                   @map("ho_ten")
  role                         String                    @default("USER") @map("vai_tro")
  emailVerified                DateTime?                 @map("ngay_xac_thuc_email")
  image                        String?                   @map("anh_dai_dien") @db.LongText
  phone                        String?                   @map("so_dien_thoai")
  createdAt                    DateTime                  @default(now()) @map("ngay_tao")
  updatedAt                    DateTime                  @default(now()) @updatedAt @map("ngay_cap_nhat")
  avatarUrl                    String?                   @map("duong_dan_anh") @db.VarChar(512)
  lastCheckIn                  DateTime?                 @map("ngay_diem_danh_cuoi")
  points                       Int                       @default(0) @map("diem_tich_luy")
  twoFactorEnabled             Boolean                   @default(false) @map("kich_hoat_hai_lop")
  failedLoginAttempts          Int                       @default(0) @map("so_lan_dang_nhap_sai")
  lockedUntil                  DateTime?                 @map("khoa_den_ngay")
  notificationPreferences      String?                   @map("tuy_chon_thong_bao") @db.LongText
  googleId                     String?                   @unique @map("ma_google")
  balance                      Decimal                   @default(0.00) @map("so_du_tai_khoan") @db.Decimal(12, 2)
  reviews                      review[]
  wishlists                    wishlist[]
  addresses                    address[]
  orders                       order[]
  pointTransactions            pointtransaction[]
  transactions                 transaction[]
  referralWalletTxs            referralwallettx[]
  cart                         cart?
  referralProfile              referralprofile?
  referralCommissionsGenerated referralcommission[]      @relation("CommissionReferred")
  referralCommissionsEarned    referralcommission[]      @relation("CommissionReferrer")
  productQAs                   productqa[]
  loginHistory                 loginhistory[]
  referralAuditLogsAsTarget    referralauditlog[]        @relation("AuditTarget")
  referralAuditLogsAsActor     referralauditlog[]        @relation("AuditActor")
  referralMilestoneRewards     referralmilestonereward[]
  liveChatsAsUser              livechat[]                @relation("userLiveChats")
  liveChatsAsAdmin             livechat[]                @relation("adminLiveChats")
  referralRelationsAsReferred  referralrelation?         @relation("ReferralReferred")
  referralRelationsAsReferrer  referralrelation[]        @relation("ReferralReferrer")
  notifications                notification[]
  userVouchers                 uservoucher[]
  twoFactorTokens              twofactortoken[]
  refundRequests               refundrequest[]
  referralCashouts             referralcashout[]

  @@map("nguoi_dung")
}

/// Mã xác thực email / đặt lại mật khẩu
model verificationtoken {
  id         Int      @id @default(autoincrement()) @map("ma_xac_thuc")
  identifier String   @map("danh_tinh")
  token      String   @unique @map("ma_thong_bao")
  expires    DateTime @map("ngay_het_han")

  @@unique([identifier, token])
  @@map("ma_xac_thuc_email")
}

/// Lịch sử đăng nhập — giám sát bảo mật
model loginhistory {
  id           Int      @id @default(autoincrement()) @map("ma_lich_su_dang_nhap")
  userId       Int      @map("ma_nguoi_dung")
  ipAddress    String?  @map("dia_chi_ip") @db.VarChar(64)
  userAgent    String?  @map("thiet_bi") @db.Text
  country      String?  @map("quoc_gia") @db.VarChar(64)
  city         String?  @map("thanh_pho") @db.VarChar(64)
  isSuspicious Boolean  @default(false) @map("dang_ngo")
  createdAt    DateTime @default(now()) @map("ngay_tao")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("lich_su_dang_nhap")
}

/// Token xác thực hai bước (2FA)
model twofactortoken {
  id        Int      @id @default(autoincrement()) @map("ma_xac_thuc_hai_lop")
  userId    Int      @map("ma_nguoi_dung")
  token     String   @map("ma_token") @db.VarChar(10)
  expires   DateTime @map("ngay_het_han")
  createdAt DateTime @default(now()) @map("ngay_tao")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("xac_thuc_hai_lop")
}

/// Địa chỉ giao hàng của người dùng
model address {
  id        Int      @id @default(autoincrement()) @map("ma_dia_chi")
  userId    Int      @map("ma_nguoi_dung")
  fullName  String   @map("ho_ten_nguoi_nhan")
  phone     String   @map("so_dien_thoai_nguoi_nhan")
  address   String   @map("dia_chi_chi_tiet")
  city      String   @map("thanh_pho")
  state     String?  @map("tinh_thanh")
  zipCode   String   @map("ma_buu_dien")
  country   String   @default("Việt Nam") @map("quoc_gia")
  isDefault Boolean  @default(false) @map("la_mac_dinh")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @default(now()) @updatedAt @map("ngay_cap_nhat")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dia_chi_giao_hang")
}

/// Giao dịch tài khoản (nạp/trừ tiền, thanh toán)
model transaction {
  id        Int      @id @default(autoincrement()) @map("ma_giao_dich")
  userId    Int      @map("ma_nguoi_dung")
  amount    Decimal  @map("so_tien") @db.Decimal(12, 2)
  type      String   @map("loai_giao_dich")
  status    String   @default("PENDING") @map("trang_thai")
  method    String?  @map("phuong_thuc")
  reference String?  @unique @map("ma_tham_chieu")
  note      String?  @map("ghi_chu") @db.Text
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @updatedAt @map("ngay_cap_nhat")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([reference])
  @@map("giao_dich_tai_khoan")
}

/// Thương hiệu sản phẩm
model brand {
  id        Int       @id @default(autoincrement()) @map("ma_thuong_hieu")
  name      String    @map("ten_thuong_hieu")
  nameEn    String?   @map("ten_thuong_hieu_en")
  slug      String    @unique @map("duong_dan_tinh")
  logo      String?   @map("anh_logo")
  isActive  Boolean   @default(true) @map("dang_hoat_dong")
  createdAt DateTime  @default(now()) @map("ngay_tao")
  updatedAt DateTime  @default(now()) @updatedAt @map("ngay_cap_nhat")
  products  product[]

  @@map("thuong_hieu")
}

/// Sản phẩm
model product {
  id                Int                    @id @default(autoincrement()) @map("ma_san_pham")
  name              String                 @map("ten_san_pham")
  nameEn            String?                @map("ten_san_pham_en")
  slug              String?                @unique @map("duong_dan_tinh")
  description       String                 @map("mo_ta") @db.Text
  descriptionEn     String?                @map("mo_ta_en") @db.Text
  price             Float                  @map("gia_ban")
  salePrice         Float?                 @map("gia_khuyen_mai")
  saleStartAt       DateTime?              @map("ngay_bat_dau_khuyen_mai")
  saleEndAt         DateTime?              @map("ngay_ket_thuc_khuyen_mai")
  isOnSale          Boolean                @default(false) @map("dang_khuyen_mai")
  badgeText         String?                @map("nhan_hieu_noi_bat")
  badgeTextEn       String?                @map("nhan_hieu_noi_bat_en")
  image             String?                @map("anh_dai_dien")
  category          String                 @map("phan_loai")
  categoryId        Int?                   @map("ma_danh_muc")
  inventory         Int                    @default(0) @map("so_luong_ton_kho")
  featured          Boolean                @default(false) @map("noi_bat")
  isVisible         Boolean                @default(true) @map("hien_thi")
  brandId           Int?                   @map("ma_thuong_hieu")
  originalPrice     Float?                 @map("gia_goc")
  tags              String?                @map("tu_khoa")
  ratingAvg         Float                  @default(0) @map("diem_danh_gia_trung_binh")
  ratingCount       Int                    @default(0) @map("so_luot_danh_gia")
  soldCount         Int                    @default(0) @map("so_luong_da_ban")
  createdAt         DateTime               @default(now()) @map("ngay_tao")
  updatedAt         DateTime               @default(now()) @updatedAt @map("ngay_cap_nhat")
  code              String?                @unique @map("ma_so_san_pham")
  weight            String?                @map("khoi_luong")
  weightEn          String?                @map("khoi_luong_en")
  deletedAt         DateTime?              @map("ngay_xoa")
  isDeleted         Boolean                @default(false) @map("da_xoa")
  searchKeywords    String?                @map("tu_khoa_tim_kiem") @db.Text
  productImages     productimage[]
  productVariants   productvariant[]
  orderItems        orderitem[]
  cartItems         cartitem[]
  productTags       producttag[]
  reviews           review[]
  wishlists         wishlist[]
  productQAs        productqa[]
  categoryRel       category?              @relation(fields: [categoryId], references: [id])
  brand             brand?                 @relation(fields: [brandId], references: [id])
  flashSaleProducts flashsaleproduct[]
  specifications    productspecification[]

  @@index([brandId])
  @@index([category])
  @@index([categoryId])
  @@index([isOnSale])
  @@index([featured])
  @@index([isVisible])
  @@index([soldCount])
  @@index([ratingAvg])
  @@fulltext([name, description])
  @@map("san_pham")
}

/// Danh mục sản phẩm (có thể lồng nhau cha-con)
model category {
  id            Int        @id @default(autoincrement()) @map("ma_danh_muc")
  name          String     @map("ten_danh_muc")
  nameEn        String?    @map("ten_danh_muc_en")
  slug          String     @unique @map("duong_dan_tinh")
  description   String?    @map("mo_ta") @db.Text
  descriptionEn String?    @map("mo_ta_en") @db.Text
  imageUrl      String?    @map("duong_dan_anh") @db.VarChar(512)
  parentId      Int?       @map("ma_danh_muc_cha")
  position      Int        @default(0) @map("vi_tri_hien_thi")
  isVisible     Boolean    @default(true) @map("hien_thi")
  isActive      Boolean    @default(true) @map("dang_hoat_dong")
  createdAt     DateTime   @default(now()) @map("ngay_tao")
  updatedAt     DateTime   @updatedAt @map("ngay_cap_nhat")
  parent        category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children      category[] @relation("CategoryParent")
  products      product[]

  @@index([parentId])
  @@index([position])
  @@index([isVisible])
  @@index([isActive])
  @@map("danh_muc_san_pham")
}

/// Nhãn/Tag để phân loại sản phẩm
model tag {
  id        Int          @id @default(autoincrement()) @map("ma_nhan")
  name      String       @map("ten_nhan")
  nameEn    String?      @map("ten_nhan_en")
  slug      String       @unique @map("duong_dan_tinh")
  isActive  Boolean      @default(true) @map("dang_hoat_dong")
  createdAt DateTime     @default(now()) @map("ngay_tao")
  updatedAt DateTime     @updatedAt @map("ngay_cap_nhat")
  products  producttag[]

  @@index([isActive])
  @@map("nhan_san_pham")
}

/// Liên kết giữa sản phẩm và nhãn (nhiều-nhiều)
model producttag {
  productId Int      @map("ma_san_pham")
  tagId     Int      @map("ma_nhan")
  createdAt DateTime @default(now()) @map("ngay_tao")
  tag       tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
  @@map("chi_tiet_nhan_san_pham")
}

/// Ảnh sản phẩm (nhiều ảnh cho một sản phẩm)
model productimage {
  id        Int      @id @default(autoincrement()) @map("ma_anh")
  productId Int      @map("ma_san_pham")
  imageUrl  String   @map("duong_dan_anh")
  altText   String?  @map("van_ban_thay_the")
  order     Int      @default(0) @map("thu_tu_hien_thi")
  isPrimary Boolean  @default(false) @map("la_anh_chinh")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @default(now()) @updatedAt @map("ngay_cap_nhat")
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
  @@map("anh_san_pham")
}

/// Biến thể sản phẩm (theo khối lượng, hương vị…)
model productvariant {
  id              Int         @id @default(autoincrement()) @map("ma_bien_the")
  productId       Int         @map("ma_san_pham")
  weight          String?     @map("khoi_luong")
  weightEn        String?     @map("khoi_luong_en")
  flavor          String?     @map("huong_vi")
  flavorEn        String?     @map("huong_vi_en")
  priceAdjustment Float       @default(0) @map("gia_dieu_chinh")
  stock           Int         @default(0) @map("so_luong_ton_kho")
  sku             String?     @unique @map("ma_sku")
  isActive        Boolean     @default(true) @map("dang_hoat_dong")
  createdAt       DateTime    @default(now()) @map("ngay_tao")
  updatedAt       DateTime    @default(now()) @updatedAt @map("ngay_cap_nhat")
  product         product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      orderitem[]
  cartItems       cartitem[]

  @@index([productId])
  @@index([isActive])
  @@map("bien_the_san_pham")
}

/// Thông số kỹ thuật sản phẩm
model productspecification {
  id        Int      @id @default(autoincrement()) @map("ma_thong_so")
  productId Int      @map("ma_san_pham")
  key       String   @map("ten_thong_so")
  keyEn     String?  @map("ten_thong_so_en")
  value     String   @map("gia_tri") @db.Text
  valueEn   String?  @map("gia_tri_en") @db.Text
  order     Int      @default(0) @map("thu_tu_hien_thi")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @updatedAt @map("ngay_cap_nhat")
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([order])
  @@map("thong_so_ky_thuat")
}

/// Hỏi đáp sản phẩm (Q&A từ khách hàng)
model productqa {
  id        Int      @id @default(autoincrement()) @map("ma_hoi_dap")
  productId Int      @map("ma_san_pham")
  userId    Int      @map("ma_nguoi_dung")
  question  String   @map("cau_hoi") @db.Text
  answer    String?  @map("cau_tra_loi") @db.Text
  isPublic  Boolean  @default(true) @map("cong_khai")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @default(now()) @updatedAt @map("ngay_cap_nhat")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("hoi_dap_san_pham")
}

/// Giỏ hàng (hỗ trợ cả khách chưa đăng nhập qua guestToken)
model cart {
  id         Int        @id @default(autoincrement()) @map("ma_gio_hang")
  userId     Int?       @unique @map("ma_nguoi_dung")
  guestToken String?    @unique @map("ma_khach_vang_lai")
  createdAt  DateTime   @default(now()) @map("ngay_tao")
  updatedAt  DateTime   @default(now()) @updatedAt @map("ngay_cap_nhat")
  items      cartitem[]
  user       user?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gio_hang")
}

/// Sản phẩm trong giỏ hàng
model cartitem {
  id        Int             @id @default(autoincrement()) @map("ma_chi_tiet_gio_hang")
  cartId    Int             @map("ma_gio_hang")
  productId Int             @map("ma_san_pham")
  variantId Int?            @map("ma_bien_the")
  quantity  Int             @default(1) @map("so_luong")
  createdAt DateTime        @default(now()) @map("ngay_tao")
  updatedAt DateTime        @default(now()) @updatedAt @map("ngay_cap_nhat")
  variant   productvariant? @relation(fields: [variantId], references: [id])
  cart      cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("chi_tiet_gio_hang")
}

/// Đơn hàng của khách
model order {
  id                  Int                  @id @default(autoincrement()) @map("ma_don_hang")
  userId              Int                  @map("ma_nguoi_dung")
  status              String               @default("PENDING") @map("trang_thai")
  subtotal            Float                @default(0) @map("tam_tinh")
  shippingFee         Float                @default(0) @map("phi_van_chuyen")
  discount            Float                @default(0) @map("giam_gia")
  total               Float                @map("tong_tien")
  couponId            Int?                 @map("ma_phieu_giam_gia")
  couponCode          String?              @map("ma_code_giam_gia")
  shippingAddress     String?              @map("dia_chi_giao_hang")
  shippingCity        String?              @map("thanh_pho_giao_hang")
  shippingZipCode     String?              @map("ma_buu_dien_giao_hang")
  shippingPhone       String?              @map("so_dien_thoai_giao_hang")
  shippingMethod      String?              @default("standard") @map("phuong_thuc_giao_hang")
  carrier             String?              @map("don_vi_van_chuyen")
  trackingCode        String?              @map("ma_van_don")
  shippedAt           DateTime?            @map("ngay_gui_hang")
  deliveredAt         DateTime?            @map("ngay_nhan_hang")
  paymentMethod       String?              @map("phuong_thuc_thanh_toan")
  paymentStatus       String               @default("UNPAID") @map("trang_thai_thanh_toan")
  paymentIntentId     String?              @map("ma_giao_dich_thanh_toan")
  notes               String?              @map("ghi_chu") @db.Text
  createdAt           DateTime             @default(now()) @map("ngay_tao")
  updatedAt           DateTime             @default(now()) @updatedAt @map("ngay_cap_nhat")
  pointsDiscount      Float?               @map("giam_gia_bang_diem")
  pointsUsed          Int?                 @map("so_diem_da_dung")
  orderItems          orderitem[]
  user                user                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCommissions referralcommission[]
  events              orderevent[]
  refundRequests      refundrequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentIntentId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus])
  @@map("don_hang")
}

/// Sản phẩm trong đơn hàng (snapshot giá tại thời điểm mua)
model orderitem {
  id           Int             @id @default(autoincrement()) @map("ma_chi_tiet_don_hang")
  orderId      Int             @map("ma_don_hang")
  productId    Int             @map("ma_san_pham")
  variantId    Int?            @map("ma_bien_the")
  quantity     Int             @map("so_luong")
  price        Float           @map("don_gia")
  nameSnapshot String?         @map("ten_san_pham_luc_mua")
  skuSnapshot  String?         @map("ma_sku_luc_mua")
  createdAt    DateTime        @default(now()) @map("ngay_tao")
  variant      productvariant? @relation(fields: [variantId], references: [id])
  order        order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      product         @relation(fields: [productId], references: [id])
  reviews      review?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([createdAt])
  @@map("chi_tiet_don_hang")
}

/// Lịch sử thay đổi trạng thái đơn hàng
model orderevent {
  id        Int      @id @default(autoincrement()) @map("ma_su_kien")
  orderId   Int      @map("ma_don_hang")
  status    String   @map("trang_thai")
  note      String?  @map("ghi_chu") @db.Text
  createdAt DateTime @default(now()) @map("ngay_tao")
  order     order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("lich_su_trang_thai_don_hang")
}

/// Yêu cầu hoàn tiền từ khách hàng
model refundrequest {
  id           Int       @id @default(autoincrement()) @map("ma_yeu_cau_hoan_tien")
  orderId      Int       @map("ma_don_hang")
  userId       Int       @map("ma_nguoi_dung")
  orderItemId  Int?      @map("ma_chi_tiet_don_hang")
  reason       String    @map("ly_do") @db.Text
  amount       Float     @map("so_tien")
  status       String    @default("PENDING") @map("trang_thai")
  adminNote    String?   @map("ghi_chu_admin") @db.Text
  refundMethod String?   @map("phuong_thuc_hoan_tien")
  bankAccount  String?   @map("tai_khoan_ngan_hang")
  bankName     String?   @map("ten_ngan_hang")
  processedAt  DateTime? @map("ngay_xu_ly")
  createdAt    DateTime  @default(now()) @map("ngay_tao")
  updatedAt    DateTime  @updatedAt @map("ngay_cap_nhat")
  order        order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("yeu_cau_hoan_tien")
}

/// Đánh giá sản phẩm (chỉ cho phép sau khi mua hàng)
model review {
  id          Int           @id @default(autoincrement()) @map("ma_danh_gia")
  productId   Int           @map("ma_san_pham")
  userId      Int           @map("ma_nguoi_dung")
  orderItemId Int?          @unique @map("ma_chi_tiet_don_hang")
  rating      Int           @map("so_sao")
  comment     String?       @map("noi_dung_danh_gia") @db.Text
  status      String        @default("PENDING") @map("trang_thai")
  adminReply  String?       @map("phan_hoi_tu_admin") @db.Text
  repliedAt   DateTime?     @map("ngay_phan_hoi")
  createdAt   DateTime      @default(now()) @map("ngay_tao")
  updatedAt   DateTime      @default(now()) @updatedAt @map("ngay_cap_nhat")
  orderItem   orderitem?    @relation(fields: [orderItemId], references: [id])
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  media       reviewmedia[]

