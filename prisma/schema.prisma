// AI CHATBOT
// ============================================================

/// Cơ sở kiến thức cho AI chatbot (FAQ tự động)
model AiKnowledge {
  id        Int      @id @default(autoincrement()) @map("ma_kien_thuc")
  category  String   @map("danh_muc")
  question  String?  @db.Text @map("cau_hoi")
  answer    String   @db.LongText @map("cau_tra_loi")
  keywords  String?  @map("tu_khoa")
  language  String   @default("vi") @map("ngon_ngu")
  priority  Int      @default(0) @map("thu_tu_uu_tien")
  isActive  Boolean  @default(true) @map("dang_hoat_dong")
  createdAt DateTime @default(now()) @map("ngay_tao")
  updatedAt DateTime @updatedAt @map("ngay_cap_nhat")

  @@index([category])
  @@index([isActive])
  @@index([language])
  @@map("kien_thuc_ai")
}

/// Lịch sử hội thoại với AI chatbot
model ConversationHistory {
  id         Int      @id @default(autoincrement()) @map("ma_lich_su")
  userId     Int?     @map("ma_nguoi_dung")
  sessionId  String   @map("ma_phien_lam_viec")
  role       String   @map("vai_tro")
  message    String   @db.LongText @map("noi_dung_tin_nhan")
  intent     String?  @map("muc_dich")
  confidence Float?   @map("do_tin_cay")
  feedback   String?  @map("phan_hoi")
  createdAt  DateTime @default(now()) @map("ngay_tao")

  @@index([createdAt])
  @@index([sessionId])
  @@index([userId])
  @@map("lich_su_hoi_thoai_ai")
}

/// Nhật ký sử dụng AI (token, model, độ trễ)
model AiUsageLog {
  id               Int      @id @default(autoincrement()) @map("ma_nhat_ky")
  task             String   @db.VarChar(50) @map("ten_nhiem_vu")
  model            String   @db.VarChar(30) @map("mo_hinh_ai")
  promptTokens     Int      @default(0) @map("so_token_dau_vao")
  completionTokens Int      @default(0) @map("so_token_dau_ra")
  totalTokens      Int      @default(0) @map("tong_so_token")
  latencyMs        Int      @default(0) @map("do_tre_ms")
  success          Boolean  @default(true) @map("thanh_cong")
  error            String?  @db.Text @map("loi_phat_sinh")
  userId           Int?     @map("ma_nguoi_dung")
  sessionId        String?  @db.VarChar(100) @map("ma_phien_lam_viec")
  createdAt        DateTime @default(now()) @map("ngay_tao")

  @@index([task])
  @@index([createdAt])
  @@index([userId])
  @@map("nhat_ky_su_dung_ai")
}

// ============================================================
// THEO DÕI HÀNH VI NGƯỜI DÙNG
// ============================================================

/// Sự kiện hành vi người dùng (click, xem, tìm kiếm…)
model BehaviorEvent {
  id         Int      @id @default(autoincrement()) @map("ma_su_kien")
  userId     Int?     @map("ma_nguoi_dung")
  sessionId  String   @map("ma_phien_lam_viec")
  eventType  String   @map("loai_su_kien")
  eventData  String?  @db.LongText @map("du_lieu_su_kien")
  url        String?  @db.VarChar(500) @map("duong_dan_url")
  referrer   String?  @db.VarChar(500) @map("nguon_truy_cap")
  deviceType String   @default("desktop") @map("loai_thiet_bi")
  createdAt  DateTime @default(now()) @map("ngay_tao")

  @@index([createdAt])
  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
  @@map("su_kien_hanh_vi")
}

// ============================================================
// GIỚI THIỆU BẠN BÈ (REFERRAL)
// ============================================================

/// Hồ sơ giới thiệu — số dư, mã, cấp bậc của người dùng
model referralprofile {
  id                       Int      @id @default(autoincrement()) @map("ma_ho_so")
  userId                   Int      @unique @map("ma_nguoi_dung")
  customCode               String?  @unique @db.VarChar(10) @map("ma_gioi_thieu_tuy_chinh")
  systemCode               String   @unique @db.VarChar(12) @map("ma_gioi_thieu_he_thong")
  verifiedPhoneCodeEnabled Boolean  @default(false) @map("xac_thuc_so_dien_thoai")
  customCodeChanges        Int      @default(0) @map("so_lan_doi_ma")
  totalInvites             Int      @default(0) @map("tong_so_loi_moi")
  qualifiedInvites         Int      @default(0) @map("loi_moi_hop_le")
  pendingBalance           Decimal  @default(0.00) @db.Decimal(12, 2) @map("so_du_cho_xu_ly")
  availableBalance         Decimal  @default(0.00) @db.Decimal(12, 2) @map("so_du_kha_dung")
  withdrawnBalance         Decimal  @default(0.00) @db.Decimal(12, 2) @map("so_du_da_rut")
  convertedBalance         Decimal  @default(0.00) @db.Decimal(12, 2) @map("so_du_da_chuyen_doi")
  tier                     String   @default("MEMBER") @db.VarChar(20) @map("cap_bac")
  fraudScore               Int      @default(0) @map("diem_gian_lan")
  isLocked                 Boolean  @default(false) @map("bi_khoa")
  lockReason               String?  @db.Text @map("ly_do_khoa")
  createdAt                DateTime @default(now()) @map("ngay_tao")
  updatedAt                DateTime @updatedAt @map("ngay_cap_nhat")
  user                     user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customCode])
  @@index([systemCode])
  @@index([tier])
  @@index([isLocked])
  @@map("ho_so_gioi_thieu")
}

/// Quan hệ ai giới thiệu ai
model referralrelation {
  id                Int                   @id @default(autoincrement()) @map("ma_quan_he")
  referrerUserId    Int                   @map("ma_nguoi_gioi_thieu")
  referredUserId    Int                   @unique @map("ma_nguoi_duoc_gioi_thieu")
  referralCodeUsed  String                @db.VarChar(20) @map("ma_da_su_dung")
  source            String                @default("LINK") @db.VarChar(10) @map("nguon_gioi_thieu")
  status            String                @default("SIGNED_UP") @db.VarChar(15) @map("trang_thai")
  ip                String?               @db.VarChar(64) @map("dia_chi_ip")
  userAgent         String?               @db.Text @map("thiet_bi")
  deviceFingerprint String?               @db.VarChar(128) @map("van_tay_thiet_bi")
  note              String?               @db.Text @map("ghi_chu")
  qualifiedAt       DateTime?             @map("ngay_hop_le")
  lockedAt          DateTime?             @map("ngay_khoa")
  createdAt         DateTime              @default(now()) @map("ngay_tao")
  updatedAt         DateTime              @updatedAt @map("ngay_cap_nhat")
  fraudSignals      referralfraudsignal[]
  referred          user                  @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer          user                  @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([status])
  @@index([createdAt])
  @@map("quan_he_gioi_thieu")
}

/// Hoa hồng từ đơn hàng của người được giới thiệu
model referralcommission {
  id               Int       @id @default(autoincrement()) @map("ma_hoa_hong")
  referrerUserId   Int       @map("ma_nguoi_gioi_thieu")
  referredUserId   Int       @map("ma_nguoi_duoc_gioi_thieu")
  orderId          Int       @map("ma_don_hang")
  rate             Decimal   @db.Decimal(5, 4) @map("ty_le_hoa_hong")
  baseAmount       Decimal   @db.Decimal(12, 2) @map("so_tien_goc")
  commissionAmount Decimal   @db.Decimal(12, 2) @map("so_tien_hoa_hong")
  status           String    @default("PENDING") @db.VarChar(12) @map("trang_thai")
  holdUntil        DateTime? @map("giu_den_ngay")
  availableAt      DateTime? @map("ngay_kha_dung")
  voidReason       String?   @db.Text @map("ly_do_huy")
  createdAt        DateTime  @default(now()) @map("ngay_tao")
  updatedAt        DateTime  @updatedAt @map("ngay_cap_nhat")
  order            order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  referred         user      @relation("CommissionReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer         user      @relation("CommissionReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@unique([orderId, referrerUserId])
  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([orderId])
  @@index([status])
  @@index([holdUntil])
  @@map("hoa_hong_gioi_thieu")
}

/// Mốc thành tích giới thiệu và phần thưởng tương ứng
model referralmilestone {
  id               Int                       @id @default(autoincrement()) @map("ma_moc_thanh_tich")
  milestone        Int                       @unique @map("so_moc")
  rewardType       String                    @db.VarChar(20) @map("loai_phan_thuong")
  rewardValue      Decimal                   @db.Decimal(12, 2) @map("gia_tri_phan_thuong")
  label            String?                   @db.VarChar(100) @map("nhan_hieu")
  labelEn          String?                   @db.VarChar(100) @map("nhan_hieu_en")
  description      String?                   @db.Text @map("mo_ta")
  descriptionEn    String?                   @db.Text @map("mo_ta_en")
  voucherConfig    String?                   @db.Text @map("cau_hinh_voucher")
  isActive         Boolean                   @default(true) @map("dang_hoat_dong")
  sortOrder        Int                       @default(0) @map("thu_tu_hien_thi")
  createdAt        DateTime                  @default(now()) @map("ngay_tao")
  updatedAt        DateTime                  @updatedAt @map("ngay_cap_nhat")
  milestoneRewards referralmilestonereward[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("moc_thanh_tich_gioi_thieu")
}

/// Phần thưởng đã được trao khi đạt mốc giới thiệu
model referralmilestonereward {
  id          Int               @id @default(autoincrement()) @map("ma_phan_thuong")
  userId      Int               @map("ma_nguoi_dung")
  milestoneId Int               @map("ma_moc_thanh_tich")
  rewardType  String            @db.VarChar(20) @map("loai_phan_thuong")
  rewardValue Decimal           @db.Decimal(12, 2) @map("gia_tri_phan_thuong")
  couponId    Int?              @map("ma_phieu_giam_gia")
  status      String            @default("GRANTED") @db.VarChar(12) @map("trang_thai")
  grantedAt   DateTime          @default(now()) @map("ngay_trao_thuong")
  createdAt   DateTime          @default(now()) @map("ngay_tao")
  updatedAt   DateTime          @updatedAt @map("ngay_cap_nhat")
  coupon      coupon?           @relation(fields: [couponId], references: [id])
  milestone   referralmilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user        user              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@index([userId])
  @@index([milestoneId])
  @@index([status])
  @@index([couponId])
  @@map("phan_thuong_moc_gioi_thieu")
}

/// Yêu cầu rút tiền hoa hồng về tài khoản ngân hàng
model referralcashout {
  id              Int       @id @default(autoincrement()) @map("ma_yeu_cau_rut_tien")
  userId          Int       @map("ma_nguoi_dung")
  amount          Decimal   @db.Decimal(12, 2) @map("so_tien")
  method          String    @db.VarChar(20) @map("phuong_thuc")
  destinationData String?   @db.Text @map("thong_tin_nhan_tien")
  status          String    @default("PENDING") @db.VarChar(12) @map("trang_thai")
  adminNote       String?   @db.Text @map("ghi_chu_admin")
  processedBy     Int?      @map("ma_nguoi_xu_ly")
  processedAt     DateTime? @map("ngay_xu_ly")
  createdAt       DateTime  @default(now()) @map("ngay_tao")
  updatedAt       DateTime  @updatedAt @map("ngay_cap_nhat")
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("yeu_cau_rut_tien_gioi_thieu")
}

/// Nhật ký kiểm toán hệ thống giới thiệu (audit log)
model referralauditlog {
  id           Int      @id @default(autoincrement()) @map("ma_nhat_ky")
  actorUserId  Int?     @map("ma_nguoi_thuc_hien")
  targetUserId Int?     @map("ma_nguoi_bi_tac_dong")
  action       String   @db.VarChar(50) @map("hanh_dong")
  entityType   String?  @db.VarChar(30) @map("loai_thuc_the")
  entityId     Int?     @map("ma_thuc_the")
  beforeData   String?  @db.LongText @map("du_lieu_truoc")
  afterData    String?  @db.LongText @map("du_lieu_sau")
  metadata     String?  @db.Text @map("thong_tin_bo_sung")
  createdAt    DateTime @default(now()) @map("ngay_tao")
  actor        user?    @relation("AuditActor", fields: [actorUserId], references: [id])
  target       user?    @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("nhat_ky_he_thong_gioi_thieu")
}

/// Tín hiệu gian lận trong quan hệ giới thiệu
model referralfraudsignal {
  id         Int              @id @default(autoincrement()) @map("ma_tin_hieu")
  relationId Int              @map("ma_quan_he")
  signalType String           @db.VarChar(30) @map("loai_tin_hieu")
  severity   String           @default("MEDIUM") @db.VarChar(10) @map("muc_do_nghiem_trong")
  score      Int              @default(10) @map("diem_gian_lan")
  details    String?          @db.Text @map("chi_tiet")
  createdAt  DateTime         @default(now()) @map("ngay_tao")
  relation   referralrelation @relation(fields: [relationId], references: [id], onDelete: Cascade)

  @@index([relationId])
  @@index([signalType])
  @@index([severity])
  @@index([createdAt])
  @@map("tin_hieu_gian_lan_gioi_thieu")
}

/// Giao dịch ví hoa hồng giới thiệu
model referralwallettx {
  id           Int      @id @default(autoincrement()) @map("ma_giao_dich")
  userId       Int      @map("ma_nguoi_dung")
  type         String   @db.VarChar(20) @map("loai_giao_dich")
  sourceType   String?  @db.VarChar(20) @map("loai_nguon_giao_dich")
  sourceId     Int?     @map("ma_nguon_giao_dich")
  direction    String   @db.VarChar(6) @map("chieu_giao_dich")
  amount       Decimal  @db.Decimal(12, 2) @map("so_tien")
  balanceAfter Decimal  @db.Decimal(12, 2) @map("so_du_sau_giao_dich")
  status       String   @default("COMPLETED") @db.VarChar(12) @map("trang_thai")
  description  String?  @db.Text @map("mo_ta")
  createdAt    DateTime @default(now()) @map("ngay_tao")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([direction])
  @@index([createdAt])
  @@map("giao_dich_vi_gioi_thieu")
}

// ============================================================
// TRANG CHỦ - CẤU HÌNH SECTION
// ============================================================

/// Cấu hình các section hiển thị trên trang chủ
model homepageSection {
  id          Int       @id @default(autoincrement()) @map("ma_section")
  key         String    @unique @db.VarChar(100) @map("khoa_section")
  title       String?   @db.VarChar(255) @map("tieu_de")
  subtitle    String?   @db.VarChar(500) @map("phu_de")
  description String?   @db.Text @map("mo_ta")
  config      Json?     @map("cau_hinh")
  type        String    @default("grid") @db.VarChar(50) @map("loai_section")
  isActive    Boolean   @default(true) @map("kich_hoat")
  position    Int       @default(0) @map("vi_tri")
  limit       Int       @default(10) @map("gioi_han_hien_thi")
  startAt     DateTime? @map("thoi_gian_bat_dau")
  endAt       DateTime? @map("thoi_gian_ket_thuc")
  createdAt   DateTime  @default(now()) @map("ngay_tao")
  updatedAt   DateTime  @default(now()) @updatedAt @map("ngay_cap_nhat")

  @@index([isActive])
  @@index([position])
  @@map("khung_trang_chu")
}
