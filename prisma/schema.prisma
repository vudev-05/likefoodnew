/// Hoa hồng từ đơn hàng của người được giới thiệu
model referralcommission {
  id               Int       @id @default(autoincrement()) @map("ma_hoa_hong")
  referrerUserId   Int       @map("ma_nguoi_gioi_thieu")
  referredUserId   Int       @map("ma_nguoi_duoc_gioi_thieu")
  orderId          Int       @map("ma_don_hang")
  rate             Decimal   @map("ty_le_hoa_hong") @db.Decimal(5, 4)
