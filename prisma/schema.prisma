// NỘI DUNG & MARKETING
// ============================================================

/// Banner quảng cáo (trang chủ, danh mục…)
model banner {
  id         Int       @id @default(autoincrement()) @map("ma_banner")
  imageUrl   String    @map("duong_dan_anh")
  title      String    @map("tieu_de")
  titleEn    String?   @map("tieu_de_en")
  subtitle   String?   @map("phu_de")
  subtitleEn String?   @map("phu_de_en")
  ctaText    String?   @map("van_ban_nut")
  ctaTextEn  String?   @map("van_ban_nut_en")
  ctaLink    String?   @map("duong_dan_nut")
  startAt    DateTime? @map("ngay_bat_dau")
  endAt      DateTime? @map("ngay_ket_thuc")
  priority   Int       @default(0) @map("thu_tu_uu_tien")
  isActive   Boolean   @default(true) @map("dang_hoat_dong")
  placement  String    @default("home") @map("vi_tri_hien_thi")
  createdAt  DateTime  @default(now()) @map("ngay_tao")
  updatedAt  DateTime  @default(now()) @updatedAt @map("ngay_cap_nhat")

