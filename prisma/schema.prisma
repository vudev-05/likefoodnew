  user                     user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customCode])
  @@index([systemCode])
  @@index([tier])
  @@index([isLocked])
  @@map("ho_so_gioi_thieu")
}

/// Quan hệ ai giới thiệu ai
model referralrelation {
