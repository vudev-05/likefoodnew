  systemCode               String   @unique @map("ma_gioi_thieu_he_thong") @db.VarChar(12)
  verifiedPhoneCodeEnabled Boolean  @default(false) @map("xac_thuc_so_dien_thoai")
  customCodeChanges        Int      @default(0) @map("so_lan_doi_ma")
  totalInvites             Int      @default(0) @map("tong_so_loi_moi")
  qualifiedInvites         Int      @default(0) @map("loi_moi_hop_le")
  pendingBalance           Decimal  @default(0.00) @map("so_du_cho_xu_ly") @db.Decimal(12, 2)
  availableBalance         Decimal  @default(0.00) @map("so_du_kha_dung") @db.Decimal(12, 2)
  withdrawnBalance         Decimal  @default(0.00) @map("so_du_da_rut") @db.Decimal(12, 2)
  convertedBalance         Decimal  @default(0.00) @map("so_du_da_chuyen_doi") @db.Decimal(12, 2)
  tier                     String   @default("MEMBER") @map("cap_bac") @db.VarChar(20)
