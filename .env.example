# ==============================================================================
# 🛠 TỆP MẪU CẤU HÌNH BIẾN MÔI TRƯỜNG (ENVIRONMENT VARIABLES)
# ==============================================================================
# HƯỚNG DẪN: 
# 1. Đổi tên file này từ `.env.example` thành `.env` (hoặc copy nội dung sang file `.env` mới).
# 2. Điền các giá trị thực tế của bạn vào (ví dụ: Key Stripe, Key OpenAI).
# 3. TUYỆT ĐỐI KHÔNG commit file `.env` chứa key thật lên Github.

NODE_ENV="development"

# ─── 1. CẤU HÌNH DOMAIN & SEO ───────────────────────────────────────────────
# Định nghĩa đường dẫn gốc của website. Bắt buộc phải đúng để sinh Sitemap và SEO.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SEO_SITE_URL="http://localhost:3000"

# ─── 2. KẾT NỐI CƠ SỞ DỮ LIỆU (DATABASE) ────────────────────────────────────
# Chuỗi kết nối tới MySQL. Định dạng: mysql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL="mysql://root:@127.0.0.1:3306/weblikefood"

# ─── 3. BẢO MẬT & ĐĂNG NHẬP (AUTH) ──────────────────────────────────────────
# NEXTAUTH_URL: Phải khớp với domain bạn đang chạy.
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET: Chuỗi ngẫu nhiên (tối thiểu 32 ký tự) dùng để mã hóa Session/Token.
# Bạn có thể tạo nhanh bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET="chuoi-bi-mat-ngau-nhien-cua-ban"

# ─── 4. ĐĂNG NHẬP BẰNG MẠNG XÃ HỘI (OAUTH) ──────────────────────────────────
# Lấy từ Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── 5. TRÍ TUỆ NHÂN TẠO (AI CHATBOT) ───────────────────────────────────────
# API Key lấy từ https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# ─── 6. CỔNG THANH TOÁN (STRIPE) ────────────────────────────────────────────
# Lấy từ Dashboard Stripe (Dùng cặp khóa Test cho môi trường dev).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Webhook Secret để Stripe báo lại cho server khi khách thanh toán thành công
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── 7. HỆ THỐNG GỬI EMAIL (SMTP) ───────────────────────────────────────────
# Có thể dùng tài khoản Gmail thông thường + Mật khẩu ứng dụng (App Password).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="LIKEFOOD <your-email@gmail.com>"

# ─── 8. THÔNG BÁO QUA TELEGRAM ──────────────────────────────────────────────
# Khi có đơn hàng mới, bot sẽ báo về điện thoại qua Telegram.
# Lấy Token từ BotFather và Chat ID từ user info.
TELEGRAM_BOT_TOKEN="1234567890:AAE..."
TELEGRAM_CHAT_ID="your-chat-id"

# ─── 9. BỘ NHỚ ĐỆM (REDIS & CACHING) ────────────────────────────────────────
# Giúp website chịu tải cao, Rate Limiting (chống spam).
REDIS_URL="redis://127.0.0.1:6379"
REDIS_PASSWORD=""

# ─── 10. CHỐNG SPAM (CLOUDFLARE TURNSTILE) ──────────────────────────────────
# Tương tự reCAPTCHA nhưng nhẹ và bảo mật hơn.
# Các key dưới đây là key test mặc định của Cloudflare (luôn pass).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ─── 11. ĐO LƯỜNG LƯU LƯỢNG (ANALYTICS) ─────────────────────────────────────
# Lấy từ Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID="G-XXXXXXXXXX"

# ─── 12. THÔNG TIN CỬA HÀNG (HIỂN THỊ LÊN UI) ───────────────────────────────
NEXT_PUBLIC_SITE_SUPPORT_PHONE="+1 402-315-8105"
NEXT_PUBLIC_SITE_SUPPORT_EMAIL="your-support-email@gmail.com"
NEXT_PUBLIC_SITE_ADDRESS="Omaha, NE 68136, United States"
NEXT_PUBLIC_FACEBOOK_URL="https://www.facebook.com/yourpage"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourhandle"
NEXT_PUBLIC_YOUTUBE_URL=""
NEXT_PUBLIC_TIKTOK_URL=""

# Bật/Tắt thanh thông báo ở trên cùng website (ON hoặc OFF)
NEXT_PUBLIC_ANNOUNCEMENT_BAR="ON"

# Các chuỗi bảo mật khác
HEALTH_SECRET="generate-a-random-64-char-string-here"
ALLOWED_ORIGIN="http://localhost:3000"

 