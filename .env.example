NODE_ENV="development"

# ─── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SEO_SITE_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────────────
# Local MySQL
DATABASE_URL="mysql://root:@127.0.0.1:3306/weblikefood"
# Cloud MySQL (PlanetScale / Railway / etc.)
# DATABASE_URL="mysql://user:password@host:3306/dbname?ssl={"rejectUnauthorized":true}"

# ─── Auth ─────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-32-char-random-secret-here"

# ─── OAuth ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI ───────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."

# ─── Stripe Payments ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Email (SMTP / Gmail) ─────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="LIKEFOOD <your-email@gmail.com>"

# ─── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="1234567890:AAE..."
TELEGRAM_CHAT_ID="your-chat-id"

# ─── Redis ────────────────────────────────────────────────────────
# Option A: Local Redis (development only)
REDIS_URL="redis://127.0.0.1:6379"
REDIS_PASSWORD=""

# Option B: Upstash Redis (RECOMMENDED for production)
# Get free account at https://upstash.com
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Security ─────────────────────────────────────────────────────
HEALTH_SECRET="generate-a-random-64-char-string-here"
ALLOWED_ORIGIN="http://localhost:3000"

# Cloudflare Turnstile CAPTCHA
# Use test keys below for development (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
# Production keys from https://dash.cloudflare.com → Turnstile

# ─── Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_TRACKING_ID="G-XXXXXXXXXX"

# ─── Store Contact ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_SUPPORT_PHONE="+1 402-315-8105"
NEXT_PUBLIC_SITE_SUPPORT_EMAIL="your-support-email@gmail.com"
NEXT_PUBLIC_SITE_ADDRESS="Omaha, NE 68136, United States"
NEXT_PUBLIC_FACEBOOK_URL="https://www.facebook.com/yourpage"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourhandle"
NEXT_PUBLIC_YOUTUBE_URL=""
NEXT_PUBLIC_TIKTOK_URL=""

# ─── UI ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ANNOUNCEMENT_BAR="ON"

# ─── Sentry (optional) ────────────────────────────────────────────
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"
# SENTRY_DSN="https://xxx@sentry.io/xxx"

# ─── Upstash Redis for Production ─────────────────────────────────
# NOTE: Add these to .env for production deployment to Vercel/Railway.
# Without Upstash, rate limiting and caching fall back to in-memory
# (fine for development, NOT safe for production with multiple instances).
#
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXXXXbGciOiJIUz..."
